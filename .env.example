# ── Server ──────────────────────────────────────────────────
PORT=3777
HOST=0.0.0.0
LOG_LEVEL=info

# ── PostgreSQL ──────────────────────────────────────────────
DATABASE_URL=postgresql://synapse:synapse@localhost:5432/synapsehub

# ── Storage ─────────────────────────────────────────────────
# Options: "s3" | "local"
STORAGE_PROVIDER=local

# Required if STORAGE_PROVIDER=local
STORAGE_LOCAL_DIR=./uploads

# Required if STORAGE_PROVIDER=s3 (S3-compatible object storage)
S3_ENDPOINT=http://localhost:9100
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=synapsehub-files
S3_REGION=us-east-1

# ── Embedding Provider ──────────────────────────────────────
# Options: "openai" | "ollama" | "mock"
EMBEDDING_PROVIDER=mock

# Required if EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=

# Required if EMBEDDING_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=nomic-embed-text

# Embedding dimension (1536 for OpenAI, 768 for most local models, 128 for mock)
EMBEDDING_DIMENSION=128

# ── Auth ────────────────────────────────────────────────────
# Master API key for bootstrapping (generate a strong random string)
MASTER_API_KEY=synapse-dev-master-key
